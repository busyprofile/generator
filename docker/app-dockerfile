# ::::::::::::::::::::::::::::::::::::::::::::::::
# :::::::::::::: Stage 1: RUNTIME ::::::::::::::::
# ::::::::::::::::::::::::::::::::::::::::::::::::

FROM php:8.3-fpm

### Установка системных зависимостей
RUN apt-get update && apt-get install -y \
    git unzip libpq-dev libzip-dev zip curl \
    libpng-dev libjpeg-dev libfreetype6-dev libgmp-dev \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo_mysql zip bcmath gmp gd pcntl \
    && pecl install redis \
    && docker-php-ext-enable redis

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

### Установка Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

RUN apt install nginx -y

WORKDIR /var/www/html

### Remove nginx default.conf
RUN truncate -s 0 /etc/nginx/conf.d/default.conf

RUN apt remove -y curl git zip unzip

### Копирование исходников laravel
COPY ./src/ ./

### Установка PHP-зависимостей и прочее
RUN composer install --no-dev --optimize-autoloader

RUN php artisan key:generate
RUN php artisan storage:link

### ! Обязательно до команды npm run build
RUN php artisan ziggy:generate resources/js/ziggy-routes.js

### Установка npm-зависимостей и сборка фронтенда
RUN npm ci || npm install
RUN npm run build

RUN chmod -R 777 storage/logs/

### Обновление php-fpm.conf перед запуском. С учётом системы на 24 CPU, 16 RAM
COPY ./configs/php-fpm/php-fpm.conf /usr/local/etc/php-fpm.d/www.conf

COPY ./docker/app-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
